# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.halvex.ai   # No trailing slash

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://...               # Supabase connection string (Transaction mode / pgBouncer)
DATABASE_URL_DIRECT=postgresql://...        # Direct connection (for migrations)

# ─── Clerk (authentication) ──────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
CLERK_SECRET_KEY=sk_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ─── Encryption ──────────────────────────────────────────────────────────────
ENCRYPTION_KEY=                             # 64 hex chars (32 bytes) — generate: openssl rand -hex 32

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── OpenAI (optional — pgvector embeddings) ─────────────────────────────────
OPENAI_API_KEY=sk-...                       # Required for pgvector deal matching (falls back to TF-IDF without it)

# ─── Slack OAuth ─────────────────────────────────────────────────────────────
SLACK_CLIENT_ID=                            # Slack app client ID (from api.slack.com/apps)
SLACK_CLIENT_SECRET=                        # Slack app client secret
SLACK_SIGNING_SECRET=                       # Slack app signing secret (for webhook verification)
# Redirect URI to register in Slack app: ${NEXT_PUBLIC_APP_URL}/api/integrations/slack/callback

# ─── Linear OAuth ────────────────────────────────────────────────────────────
LINEAR_CLIENT_ID=                           # Linear OAuth app client ID (from linear.app/settings/api/applications)
LINEAR_CLIENT_SECRET=                       # Linear OAuth app client secret
LINEAR_REDIRECT_URI=                        # e.g. https://app.halvex.ai/api/integrations/linear/callback
# Scopes required: read,write,issues:create

# ─── HubSpot (optional) ──────────────────────────────────────────────────────
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=

# ─── Stripe (billing) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
